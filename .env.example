# 机器人自己的 QQ 号（必须配置，用于识别群 @ 消息）
QQ_BOT_QQ=123456789

# NapCat HTTP API 地址（用于机器人回复 QQ 消息）
NAPCAT_API=http://127.0.0.1:3000

# NapCat Access Token（如果配置了鉴权）
NAPCAT_TOKEN=your_napcat_token

# 青龙面板 Open API 地址（兼容旧插件；WPS/顺丰 请配置到各自项目 .env）
QL_URL=http://127.0.0.1:5700

# 青龙应用 Client ID / Client Secret（兼容旧插件；WPS/顺丰 请配置到各自项目 .env）
QL_CLIENT_ID=your_client_id
QL_CLIENT_SECRET=your_client_secret

# 允许的 QQ 管理员，多个用逗号分隔，留空表示不限制
ADMIN_QQ=你的QQ号

# 机器人 WebSocket 监听配置（与 NapCat 反向 WS 对应）
WS_HOST=0.0.0.0
WS_PORT=8080
WS_PATH=/onebot/v11/ws/

# 反向 WS 鉴权 Token（可选，与 NapCat 中配置一致）
WS_TOKEN=

# 插件目录，默认 bot/plugins
PLUGIN_DIR=bot/plugins

# 会话超时时间（秒）
SESSION_TIMEOUT=300

# WPS 项目目录（QL-WPS 仓库路径，WPS 插件会读取这里的 .env）
WPS_PROJECT_DIR=/opt/QL-WPS

# WPS 自动脚本路径（兼容旧变量 WPS_AUTO_PATH，推荐使用 WPS_SCRIPT_PATH）
WPS_SCRIPT_PATH=/opt/QL-WPS/wps_auto.py

# 顺丰配置请放到 /opt/QL-SF/.env
